# exit i3 (logs you out of your X session)

# Screenshots

bindsym $mod+Shift+q exec i3 exit
bindsym $mod+Shift+e exec --no-startup-id st -e yazi
bindsym $mod+m exec --no-startup-id dunstctl history-pop


bindsym Ctrl+Print exec --no-startup-id maim "/home/$USER/Pictures/$(date)"
bindsym $mod+Shift+Print exec --no-startup-id maim --select "/home/$USER/Pictures/$(date)"

## Clipboard Screenshots
bindsym $mod+Print exec --no-startup-id maim | xclip -selection clipboard -t image/png
bindsym Print exec --no-startup-id maim --select | xclip -selection clipboard -t image/png
bindsym $mod+F12 exec --no-startup-id togglecomp
bindsym $mod+l exec --no-startup-id betterlockscreen -l dimblur --display 1 --span

bindsym $mod+t exec --no-startup-id polybar-msg cmd toggle

# resize window (you can also use the mouse for that)
mode "resize" {
        bindsym j resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym l resize shrink height 10 px or 10 ppt
        bindsym ccedilla resize grow width 10 px or 10 ppt

        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

set $bg-color 	         #1D5B79
set $inactive-bg-color   #222222
set $text-color          #f3f4f5
set $inactive-text-color #676E7D
set $urgent-bg-color     #d7c483
set $bar-window			 #78824b

# window colors
#                       border              background         text                 indicator
client.focused          $urgent-bg-color   $urgent-bg-color   $text-color          $urgent-bg-color
client.unfocused        $inactive-bg-color $inactive-bg-color $inactive-text-color #222222
client.focused_inactive $inactive-bg-color $inactive-bg-color $inactive-text-color #222222
client.urgent           $urgent-bg-color    $urgent-bg-color   $text-color          #222222

# Inner gaps for all windows: space between two adjacent windows (or split containers).
gaps inner 5
gaps outer 2
gaps top 30

default_border pixel 1
default_floating_border pixel 0

title_align center

exec xrandr --output eDP-1 --mode 1920x1080 --pos 0x0 --rotate normal --output HDMI-1 --primary --mode 1920x1080 --pos 1920x1028 --rotate normal
exec --no-startup-id export PATH=$HOME/.local/bin:$PATH:/go/bin/:$PATH
exec --no-startup-id "dbus-update-activation-environment --all"
exec --no-startup-id "/usr/bin/gnome-keyring-daemon --start --components=secrets"
exec --no-startup-id dunst
exec --no-startup-id fastcompmgr
exec --no-startup-id polybar info
exec --no-startup-id polybar workspaces
exec --no-startup-id xsettingsd
exec --no-startup-id xwallpaper --zoom Wallpapers/wallpaper.jpg
