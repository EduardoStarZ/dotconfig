# Sets the modifier to the windows key
set $mod Mod4


# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:JetBrainsMono 0


# Start XDG autostart .desktop files using dex. See also
# https://wiki.archlinux.org/index.php/XDG_Autostart
exec --no-startup-id dex --autostart --environment i3


# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork


# Use pactl to adjust volume in PulseAudio.
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5% && ./.local/bin/volume-control
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5% && ./.local/bin/volume-control
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && ./.local/bin/volume-control
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status


# Brightness controls using brightnessctl.
bindsym XF86MonBrightnessUp exec --no-startup-id brightnessctl set 1%+
bindsym XF86MonBrightnessDown exec --no-startup-id brightnessctl set 1%-


# Use Mouse+$mod to drag floating windows to their wanted position.
floating_modifier $mod


# move tiling windows via drag & drop by left-clicking into the title bar,
# or left-clicking anywhere into the window while holding the floating modifier.
tiling_drag modifier titlebar


# Start an instance of Simple Terminal.
bindsym $mod+Return exec st


# Kill the focused window.
bindsym $mod+q kill


# start the Rofi program launcher into drun mode (only shows Desktop applications,
# not binaries).
bindsym $mod+space exec --no-startup-id rofi -show drun


# Focused window/screen changing:
# $mod + Arrow Left: focus leftwards.
# $mod + Arrow Down: focus downwards.
# $mod + Arrow Up: focus upwards.
# $mod + Arrow Right: focus rightwards.
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right


# Focused Window position/screen changing:
# $mod + Shift + Arrow Left: move leftwards.
# $mod + Shift + Arrow Down: move downwards.
# $mod + Shift + Arrow Up: move upwards.
# $mod + Shift + Arrow Right: move rightwards.
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right


# Split windows in horizontal orientation.
bindsym $mod+h split h


# Split in vertical orientation.
bindsym $mod+v split v


# Enter fullscreen mode for the focused window.
bindsym $mod+f fullscreen toggle


# Change container layout (stacked, tabbed, toggle split).
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split


# Toggle tiling / floating for focused window.
bindsym $mod+Tab floating toggle


# Change focus between tiling / floating windows.
bindsym $mod+d focus mode_toggle


# Define names for default workspaces for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"
set $ws11 "11"
set $ws12 "12"


# Assigning specific window classes into specific workspaces by default
# These can be moved to other workspaces after launch manually.
assign [class="minecraft-launcher"] $ws2
assign [class="Minecraft Launcher"] $ws2
assign [class="steam"] $ws2
assign [class="steamwebhelper"] $ws2
assign [class="zen"] $ws3
assign [class="firefox"] $ws3
assign [class="legcord"] $ws11
assign [class="discord"] $ws11
assign [class="vesktop"] $ws11
assign [class="Spotify"] $ws12


# Switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10
bindsym $mod+x workspace number $ws11
bindsym $mod+z workspace number $ws12


# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10
bindsym $mod+Shift+x move container to workspace number $ws11
bindsym $mod+Shift+z move container to workspace number $ws12


# Reload the configuration file.
bindsym $mod+Shift+c reload


# Restart i3 inplace (preserves your layout/session, can be used to hot upgrade i3).
bindsym $mod+Shift+r restart


# Exits i3 (logs you out of your X session).
bindsym $mod+Shift+q exec i3 exit


# Keybind to start musikcube without opening a Simple Terminal instance.
bindsym $mod+Shift+e exec --no-startup-id st -e musikcube


# Keybind to resend the last notification sent by dunst.
bindsym $mod+m exec --no-startup-id dunstctl history-pop


# Keybind to take a fullscreen screenshot and send it to the default screenshot folder.
bindsym Ctrl+Print exec --no-startup-id maim "/home/$USER/Pictures/$(date).png"


# Keybind to take a selected area screenshot and send it to the default screenshot folder.
bindsym $mod+Shift+Print exec --no-startup-id maim --select "/home/$USER/Pictures/$(date).png"


# Keybind to take a fullscreen screenshot and send it to clipboard.
bindsym $mod+Print exec --no-startup-id maim | xclip -selection clipboard -t image/png


# Keybind to take a selected area screenshot and send it to clipboard.
bindsym Print exec --no-startup-id maim --select | xclip -selection clipboard -t image/png


# Keybind that toggles turns on/off the current compositor.
bindsym $mod+F12 exec --no-startup-id togglecomp


# Keybind that activates screen locking under betterlockscreen.
bindsym $mod+l exec --no-startup-id betterlockscreen -l dimblur --display 1 --span


# Keybind that toggles on/off the visibilty of all polybar bars.
bindsym $mod+t exec --no-startup-id polybar-msg cmd toggle

# Window resize mode 
mode "resize" {

        # Pressing left will shrink the window’s width.
        # Pressing right will grow the window’s width.
        # Pressing up will shrink the window’s height.
        # Pressing down will grow the window’s height.
        bindsym j resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym l resize shrink height 10 px or 10 ppt
        bindsym ccedilla resize grow width 10 px or 10 ppt

        # Same bindings, but for the arrow keys.
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        # Back to normal: Enter or Escape or $mod+r.
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}


# Keybind to enter resize mode.
bindsym $mod+r mode "resize"


# Colors setup for i3.
set $bg-color 	         #1D5B79
set $inactive-bg-color   #222222
set $text-color          #f3f4f5
set $inactive-text-color #676E7D
set $urgent-bg-color     #d7c483
set $bar-window			 #78824b


# Window colors
#                       border              background         text                 indicator
client.focused          $urgent-bg-color   $urgent-bg-color   $text-color          $urgent-bg-color
client.unfocused        $inactive-bg-color $inactive-bg-color $inactive-text-color #222222
client.focused_inactive $inactive-bg-color $inactive-bg-color $inactive-text-color #222222
client.urgent           $urgent-bg-color    $urgent-bg-color   $text-color          #222222


# Inner gaps for all windows: space between two adjacent windows (or split containers).
gaps inner 5


# Outer gaps for all windows: space along the screen edges.
gaps outer 2


# More gap for upwards on all windows to comport polybar bars.
gaps top 30


# Defines the border size in pixels.
default_border pixel 1


# Execute all of the commands below on i3 startup.
exec --no-startup-id xwallpaper --tile Wallpapers/wallpaper.jpg
exec --no-startup-id export PATH=$HOME/.local/bin:$PATH:/go/bin/:$PATH
exec --no-startup-id "dbus-update-activation-environment --all"
exec --no-startup-id "/usr/bin/gnome-keyring-daemon --start --components=secrets"
exec --no-startup-id polybar info
exec --no-startup-id polybar workspaces
exec --no-startup-id dunst
exec --no-startup-id picom -b
exec --no-startup-id xsettingsd
exec_always --no-startup-id export XDG_CURRENT_DESKTOP=GNOME
exec_always --no-startup-id export XDG_SESSION_DESKTOP=GNOME
